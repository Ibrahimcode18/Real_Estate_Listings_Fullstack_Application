{
    "definitions": {
        "user": {
            "id": "/user",
            "type": "object",
            "properties": {
                "username": { "type": "string", "minLength": 3, "maxLength": 15, "pattern": "^[A-Za-z0-9]+$" },
                "email": { "type": "string", "format": "email", "maxLength": 64 },
                "password": { "type": "string", "minLength": 8, "maxLength": 15 },
                "role": { "type": "string", "enum": ["user", "admin", "agent"] },
                "firstName": { "type": "string", "maxLength": 32 },
                "lastName": { "type": "string", "maxLength": 32 }
            },
            "required": ["username", "email", "password"],
            "additionalProperties": false
        },
        "userUpdate": {
            "type": "object",
            "properties": {
                "firstName": { "type": "string", "maxLength": 32 },
                "lastName": { "type": "string", "maxLength": 32 },
                "password": { "type": "string", "minLength": 8, "maxLength": 15 },
                "email": { "type": "string", "format": "email", "maxLength": 64 }
            },
            "additionalProperties": false
        }
    }
}